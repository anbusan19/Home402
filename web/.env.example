# ─────────────────────────────────────────────────────────────────────────────
# Maid402 Web UI — Environment Variables
# Copy this file to web/.env.local before running the Next.js dev server.
#
#   cp web/.env.local.example web/.env.local
#
# These vars are separate from the root .env used by the agent.
# ─────────────────────────────────────────────────────────────────────────────


# ── Agent API URL ─────────────────────────────────────────────────────────────
# URL of the running agent HTTP server.
# Next.js API routes (/api/chat, /api/health) proxy requests here server-side.
# Must match WEB_API_PORT / AGENT_BASE_URL in the root .env.

AGENT_URL=http://localhost:3004


# ── Public Agent URL (browser-visible) ───────────────────────────────────────
# Shown in the web UI's API info panel as the example curl endpoint.
# For local dev this is the same as AGENT_URL.
# For a deployed instance replace with your public domain.

NEXT_PUBLIC_AGENT_URL=http://localhost:3004
