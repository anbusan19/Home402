# ─────────────────────────────────────────────────────────────────────────────
# Maid402 — Environment Variables
# Copy this file to .env and fill in each value before running the agent.
#
#   cp .env.example .env
#
# Every section below links to where you can get the required credentials.
# ─────────────────────────────────────────────────────────────────────────────


# ── Telegram ──────────────────────────────────────────────────────────────────
# Create a bot via @BotFather on Telegram → /newbot
# Docs: https://core.telegram.org/bots/tutorial

TELEGRAM_BOT_TOKEN=


# ── LLM — Groq ────────────────────────────────────────────────────────────────
# Sign up at https://console.groq.com → API Keys → Create Key

GROQ_API_KEY=


# ── Zepto Automation ──────────────────────────────────────────────────────────
# Indian mobile number registered on Zepto (without the +91 country code)
# Example: 9876543210

ZEPTO_PHONE=


# ── ERC-8004 Identity + Reputation (Base Sepolia) ────────────────────────────
# Generate a wallet with any Ethereum tool (e.g. cast wallet new from Foundry,
# or MetaMask → export private key).
# Fund the payer wallet:
#   ETH  → https://www.alchemy.com/faucets/base-sepolia
#   USDC → https://faucet.circle.com
#
# OPERATOR_PRIVATE_KEY  — wallet that signs x402 payment headers (payer)
# OPERATOR_WALLET       — treasury address that receives the 1 USDC fee
# Both can be the same wallet for local testing.

OPERATOR_PRIVATE_KEY=
OPERATOR_WALLET=
IDENTITY_REGISTRY_ADDRESS=0x8004A169FB4a3325136EB29fA0ceB6D2e539a432
REPUTATION_REGISTRY_ADDRESS=0x8004BAa17C55a88189AE136b182e5fdA19dE9b63
SEPOLIA_RPC_URL=https://go.getblock.io/44d3bd24255a43ab92d05b65011aff3d


# ── Filecoin — Receipt Storage (Calibration testnet) ─────────────────────────
# Reuse your Ethereum private key or generate a separate one.
# Faucet: https://faucet.calibration.fildev.network

FILECOIN_PRIVATE_KEY=
FILECOIN_RPC_URL=https://filecoin-calibration.lava.build
GLIF_TOKEN=


# ── Storacha — Decentralised Agent Memory ────────────────────────────────────
# Run the setup script to create a space automatically:
#
#   pnpm setup:storacha
#
# It will open a browser login at https://console.storacha.network,
# then print the STORACHA_SPACE_DID — copy it here.

STORACHA_EMAIL=
STORACHA_SPACE_DID=


# ── NEAR Protocol — On-Chain Spend Cap ───────────────────────────────────────
# Create a testnet account at https://testnet.mynearwallet.com
# Then deploy the contract:
#
#   pnpm deploy:near
#
# NEAR_PRIVATE_KEY is printed after account creation (ed25519:... format).

NEAR_ACCOUNT_ID=yourname.testnet
NEAR_PRIVATE_KEY=
NEAR_CONTRACT_ID=yourname.testnet
NEAR_CONTRACT_HASH=


# ── Impulse AI — Restock Prediction ──────────────────────────────────────────
# Sign up at https://impulselabs.ai → Dashboard → API Keys

IMPULSE_API_KEY=
IMPULSE_MODEL_ENDPOINT=https://inference.impulselabs.ai/infer
IMPULSE_DEPLOYMENT_ID=


# ── x402 Payment Endpoint ────────────────────────────────────────────────────
# Leave as-is to use the local mock server during development.
# Replace with your deployed endpoint for production.

X402_ENDPOINT=http://localhost:3004/api/pay
X402_MOCK_SERVER_PORT=3004


# ── HTTP / Web API ────────────────────────────────────────────────────────────
WEB_API_PORT=3004
AGENT_BASE_URL=http://localhost:3004
